#!/usr/bin/env bash
echo "zfs $*" >> "${MOCKLOG:-/dev/null}"
case "$1" in
  # `zfs list -H -o mountpoint <dataset>` — used to assert the disk/XML are on the dataset.
  list)     echo "${ZFS_MOUNTPOINT:-/export/coworkvm}" ;;
  # ZFS_FAIL=1 makes `zfs snapshot` fail, to test that the guest is thawed anyway.
  snapshot) [ "${ZFS_FAIL:-0}" = "1" ] && exit 1 ;;
esac
exit 0
