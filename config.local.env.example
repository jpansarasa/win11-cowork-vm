# config.local.env.example — copy to config.local.env and edit.
# Gitignored: put anything site-specific here rather than in config.env, so a
# public clone never carries your addresses. Sourced AFTER config.env, so it wins.

# Point the guest at a service whose name resolves internally to a LAN address
# (split-horizon DNS) that the cowork cage correctly drops. Requires NAT
# reflection on the gateway. See buildspec "Reaching the operator remotely".
#DNS_OVERRIDES="ntfy.example.com:203.0.113.10"

# Console connect string used only to print a copy-pasteable command.
#HOST_ADDR=you@your-host
