# Single source of tunables for the Cowork VM host scaffolding.
VM_NAME=win11-cowork
RAM_MB=16384
VCPUS=4
DISK_GB=100
NET_NAME=cowork-net
BRIDGE=virbr-cowork
SUBNET=10.77.0.0/24
NETMASK=255.255.255.0
GATEWAY=10.77.0.1
DHCP_START=10.77.0.10
DHCP_END=10.77.0.100
IMAGE_DIR=/var/lib/libvirt/images
DISK_PATH=/export/coworkvm/win11-cowork.qcow2
WIN_ISO=${IMAGE_DIR}/Win11.iso
VIRTIO_ISO=${IMAGE_DIR}/virtio-win.iso
DNS_LOG=/var/log/libvirt/cowork-dns.log
SNI_LOG=/var/log/libvirt/cowork-sni.log
LOG_RETAIN_DAYS=14
ZFS_DATASET=tank/coworkvm                             # dataset holding the qcow2 + exported XML; snapshotted for recovery
ZFS_EXPORT_DIR=/export/coworkvm/state
# Address you already SSH to for this host — only used to print the virt-viewer connect string.
HOST_ADDR=you@your-host

# Split-horizon DNS overrides for the guest network (optional; space-separated
# "hostname:ip" pairs). The guest resolver answers these directly instead of
# forwarding upstream.
#
# Why this exists: a self-hosted service can resolve INTERNALLY to a LAN address
# (e.g. the router) while being reachable publicly. The guest sits inside the LAN,
# so it gets the LAN answer -- which the cowork cage drops as lateral movement.
# Pointing the guest at the public address instead keeps the cage intact.
# Requires NAT reflection/hairpin on the gateway, and pins a WAN IP: if that IP
# changes, the override goes stale and the guest silently cannot reach the service.
#   DNS_OVERRIDES="ntfy.example.com:203.0.113.10"
DNS_OVERRIDES=""

# Hostnames whose DNS_OVERRIDES entry should track the host's CURRENT public IP,
# refreshed by the cowork-wandns timer (stage 36). Use when the WAN address is
# dynamic (DDNS): a pinned IP goes stale on renumber and the guest then silently
# cannot reach the service. Empty disables the timer entirely.
#   DNS_WAN_HOSTS="ntfy.example.com"
DNS_WAN_HOSTS=""
# Where to learn the public IP. First response shaped like a bare IPv4 wins.
WAN_IP_LOOKUPS="https://api.ipify.org https://icanhazip.com https://ifconfig.me/ip"
