# Single source of tunables for the Cowork VM host scaffolding.
VM_NAME=win11-cowork
RAM_MB=16384
VCPUS=4
DISK_GB=100
NET_NAME=cowork-net
BRIDGE=virbr-cowork
SUBNET=10.77.0.0/24
NETMASK=255.255.255.0
GATEWAY=10.77.0.1
DHCP_START=10.77.0.10
DHCP_END=10.77.0.100
IMAGE_DIR=/var/lib/libvirt/images
DISK_PATH=/export/coworkvm/win11-cowork.qcow2
WIN_ISO=${IMAGE_DIR}/Win11.iso
VIRTIO_ISO=${IMAGE_DIR}/virtio-win.iso
DNS_LOG=/var/log/libvirt/cowork-dns.log
SNI_LOG=/var/log/libvirt/cowork-sni.log
LOG_RETAIN_DAYS=14
ZFS_DATASET=tank/coworkvm                             # dataset holding the qcow2 + exported XML; snapshotted for recovery
ZFS_EXPORT_DIR=/export/coworkvm/state
# Address you already SSH to for this host — only used to print the virt-viewer connect string.
HOST_ADDR=you@your-host

# --- operator notifications (host-mediated relay, stage 37) ------------------
# The guest spools notification requests; the HOST publishes them to ntfy. The
# guest never holds the token and never talks to ntfy. Empty NTFY_URL disables
# the relay entirely (nothing is installed).
#   NTFY_URL="https://ntfy.example.com/your-topic"
NTFY_URL=""
# Publish-only token, readable only by root on the HOST - never in the guest.
NTFY_TOKEN_FILE="/etc/cowork/ntfy.token"
# Spool directory inside the guest (guest/notify.ps1 writes here).
NOTIFY_OUTBOX="C:\\ProgramData\\cowork\\outbox"
# How often the host drains the spool.
NOTIFY_POLL_INTERVAL="1min"
